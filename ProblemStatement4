# =========================================
# PROBLEM 4: STRESS DETECTION LOGIC
# =========================================
def calculate_hrv_metrics(r_peaks, fs):
    """
    Calculates Heart Rate Variability (HRV) metrics from R-peaks.
    """
    # 1. Calculate R-R intervals in seconds
    rr_intervals = np.diff(r_peaks) / fs
    
    if len(rr_intervals) < 2:
        return 0, 0, 0, rr_intervals

    # 2. SDNN: Standard Deviation of NN intervals (Time Domain)
    sdnn = np.std(rr_intervals)

    # 3. RMSSD: Root Mean Square of Successive Differences
    # Most sensitive indicator of stress (vagal tone)
    diff_rr = np.diff(rr_intervals)
    rmssd = np.sqrt(np.mean(diff_rr ** 2))

    # 4. Mean RR
    mean_rr = np.mean(rr_intervals)

    return mean_rr, sdnn, rmssd, rr_intervals

import datetime

# =========================================
# PROBLEM 4: ENHANCED STRESS LOGIC
# =========================================

def detect_stress_state_advanced(hr, rmssd, rr_intervals, quality, current_time=None):
    """
    Advanced Stress Detection with:
    1. Circadian Rhythm Check (Time of Day)
    2. Dynamic Thresholds (Relative Change)
    """
    
    # 1. QUALITY CHECK
    if quality == "POOR":
        return "CANNOT ASSESS (Poor Signal)", 0.0

    # 2. CIRCADIAN RHYTHM CHECK (Tackling Sleep vs Stress)
    # If no time provided, assume current system time
    if current_time is None:
        current_time = datetime.datetime.now().time()
    
    hour = current_time.hour
    
    # Define "Sleep Hours" (e.g., 11 PM to 6 AM)
    is_sleep_time = (hour >= 23) or (hour < 6)

    # 3. DYNAMIC THRESHOLD (Tackling Individual Variability)
    # Instead of fixed thresholds, we look at the VARIATION in the signal itself.
    # We calculate the Coefficient of Variation (CV) for the current window.
    if len(rr_intervals) > 1:
        mean_rr = np.mean(rr_intervals)
        std_rr = np.std(rr_intervals)
        cv = std_rr / mean_rr  # Relative variability
    else:
        cv = 0

    # --- CLASSIFICATION LOGIC ---
    
    # Case A: Sleep Mode
    if is_sleep_time:
        # During sleep, low HR and high variability are normal.
        # We suppress "Relaxed" alerts to avoid redundant info, focus on anomalies.
        if hr > 100: 
            return "UNUSUAL NIGHTTIME HR (Check Health)", 0.9
        else:
            return "SLEEP / REST STATE", 0.95

    # Case B: Stress Detection (Relative to Normal)
    # A sudden drop in variability (CV < 0.05 implies very rigid heart)
    # AND High HR implies Acute Stress
    
    if hr > 90 and cv < 0.05:
        return "HIGH STRESS (Low Variability)", 0.90
        
    # Case C: "Flow State" or Exercise
    # High HR but STILL High Variability (Body is working, but not "stressed" mentally)
    elif hr > 90 and cv > 0.10:
        return "ACTIVE / HIGH ENERGY (Not Stress)", 0.80
        
    # Case D: Relaxed
    elif hr < 75 and rmssd > 0.050:
        return "RELAXED", 0.90

    # Case E: Normal
    else:
        return "NORMAL / NEUTRAL", 0.70

