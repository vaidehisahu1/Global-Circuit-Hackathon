plot_signal = filtered / np.max(np.abs(filtered))
smooth = savgol_filter(plot_signal, 31, 2)

# ---- FULL SIGNAL
plt.figure(figsize=(14,4))
plt.plot(time, smooth, color='black')
ax = plt.gca()
add_ecg_grid(ax)
plt.title("Full ECG Signal (ECG Paper Style)")
plt.tight_layout()
plt.show()

# ---- ZOOM
plt.figure(figsize=(14,4))
plt.plot(time, smooth, color='black')

if len(r_peaks):
